  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@solvapay.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "https://app.solvapay.com"
    }
  },
  "redirects": [
    {
      "source": "/get-started",
      "destination": "/"
    },
    {
      "source": "/get-started/index",
      "destination": "/"
    },
    {
      "source": "/mcp-pay/create-hosted-mcp-pay-product",
      "destination": "/no-code-mcp/create-no-code-mcp-product"
    },
    {
      "source": "/mcp-pay/:slug",
      "destination": "/no-code-mcp/:slug"
    }
  ],
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
