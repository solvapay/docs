{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "SolvaPay Documentation",
  "colors": {
    "primary": "#3a3a3a",
    "light": "#4f4f4f",
    "dark": "#2b2b2b"
  },
  "fonts": {
    "family": "Inter"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "getting-started/index",
              "getting-started/create-account",
              "getting-started/choose-your-path",
              "getting-started/create-product",
              "getting-started/test-in-sandbox",
              "getting-started/go-live"
            ]
          },
          {
            "group": "MCP Pay",
            "icon": "credit-card",
            "pages": [
              "mcp-pay/overview",
              "mcp-pay/quick-start",
              "mcp-pay/create-hosted-mcp-pay-product",
              "mcp-pay/authentication",
              "mcp-pay/hosted-pages",
              "mcp-pay/best-practices"
            ]
          },
          {
            "group": "Wallet",
            "icon": "wallet",
            "pages": [
              "wallet/overview",
              "wallet/how-it-works",
              "wallet/sdk-integration",
              "wallet/provider-integration",
              "wallet/vouchers",
              "wallet/security"
            ]
          },
          {
            "group": "MCP Server",
            "icon": "bot",
            "pages": [
              "mcp-server/getting-started",
              "mcp-server/installation",
              "mcp-server/tools",
              "mcp-server/examples",
              "mcp-server/faq"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "icon": "code",
        "groups": [
          {
            "group": "TypeScript SDK",
            "icon": "braces",
            "pages": [
              "sdks/typescript/intro",
              "sdks/typescript/getting-started/introduction",
              "sdks/typescript/getting-started/installation",
              "sdks/typescript/getting-started/quick-start",
              "sdks/typescript/getting-started/core-concepts",
              "sdks/typescript/guides/architecture",
              "sdks/typescript/guides/express",
              "sdks/typescript/guides/nextjs",
              "sdks/typescript/guides/react",
              "sdks/typescript/guides/mcp",
              "sdks/typescript/guides/custom-auth",
              "sdks/typescript/guides/error-handling",
              "sdks/typescript/guides/testing",
              "sdks/typescript/guides/performance",
              "sdks/typescript/guides/webhooks",
              "sdks/typescript/examples/overview",
              "sdks/typescript/publishing"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "square-terminal",
        "openapi": [
          "api-reference/openapi.json"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "SolvaPay website",
          "href": "https://solvapay.com",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/solvapay",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@solvapay.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Console",
      "href": "https://app.solvapay.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/solvapay",
      "github": "https://github.com/solvapay",
      "linkedin": "https://linkedin.com/company/solvapay"
    }
  }
}
